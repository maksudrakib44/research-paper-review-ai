# Groq API key is now OPTIONAL (not needed for free Hugging Face mode)
# GROQ_API_KEY=your_key_here

# Hugging Face settings
USE_HUGGINGFACE=true
HF_MODEL=mistral  # Options: mistral, phi, llama, gemma

# Rest of settings remain the same
CHUNK_SIZE=1024
CHUNK_OVERLAP=128
TOP_K_DENSE=15
TOP_K_BM25=15
TOP_K_RERANK=8
HYBRID_ALPHA=0.6